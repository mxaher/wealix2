# Wealix.app — Required Environment Variables
# Copy to .env.local and fill in real values. Never commit real values to git.

# Clerk Authentication
# Bug #8 fix: use pk_test_ prefix for local development — NEVER commit a pk_live_ key.
# Obtain your development key from the Clerk dashboard under your development instance.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_clerk_dev_publishable_key
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
# Bug #17 fix: set your Clerk instance key ID here to enable stale-handshake detection.
# Find this in your Clerk dashboard. Must be set explicitly — no hardcoded fallback.
CLERK_EXPECTED_KID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/wealix

# Redis (Upstash recommended for Edge compatibility)
REDIS_URL=redis://localhost:6379

# Upstash Redis (Edge/Cloudflare Worker compatible)
# Get these from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# CSRF
CSRF_SECRET=replace_with_256bit_random_secret

# AI routing strategy
# Supported strategies: primary, fallback, merge, ab
# Bug #19: when strategy=ab, AB_PERCENT must be > 0 and a distinct test provider must be configured.
AI_ADVISOR_STRATEGY=primary
AI_ADVISOR_PRIMARY_PROVIDER=nvidia
AI_ADVISOR_FALLBACK_PROVIDER=gemma
AI_ADVISOR_AB_TEST_PROVIDER=gemma
AI_ADVISOR_AB_PERCENT=0

# AI
OPENAI_API_KEY=replace_me

# Admin Panel Worker (required — no fallback)
WEALIX_ADMIN_PANEL_HOST=

# External Data Providers
# Bug #20: these keys are required for market data. Missing keys will show graceful
# 'Market data unavailable' states rather than crashes — but all three should be set
# for full functionality.
DATALAB_API_KEY=
DATALAB_API_BASE=https://www.datalab.to

# Market Data
TWELVE_DATA_API_KEY=replace_me

# sent.dm messaging
SENTDM_API_KEY=
SENTDM_SENDER_ID=
SENTDM_BASE_URL=https://api.sent.dm
SENTDM_WEBHOOK_SIGNING_SECRET=

# Cloudflare Email Sending
# Enable Email Sending on a sending subdomain such as notifications.wealix.app first.
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM=notify@notifications.wealix.app
CLOUDFLARE_EMAIL_FROM_NAME=Wealix
CLOUDFLARE_EMAIL_REPLY_TO=support@wealix.app

# Internal routes / schedulers
AGENTS_SECRET_KEY=

# Playwright E2E (CI only — never set in production)
# Bug #9 fix: E2E_AUTH_SECRET must be >= 32 characters. Shorter secrets disable the bypass.
# Generate a secure secret: openssl rand -hex 32
# NEVER use a simple string like 'wealix-e2e-secret' — it will be rejected.
NEXT_PUBLIC_E2E_AUTH_ENABLED=false
E2E_AUTH_SECRET=
E2E_AUTH_USER_ID=e2e-user
E2E_AUTH_USER_EMAIL=e2e@wealix.local
E2E_AUTH_USER_NAME=Wealix E2E
E2E_AUTH_SUBSCRIPTION_TIER=pro
E2E_STORAGE_DIR=.e2e/.runtime
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
