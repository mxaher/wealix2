# App URL
NEXT_PUBLIC_APP_URL=https://wealix.app

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Stripe Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_CORE_MONTHLY=price_core_monthly_placeholder
STRIPE_PRICE_CORE_ANNUAL=price_core_annual_placeholder
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_placeholder
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual_placeholder

# AI & LLM (NVIDIA)
# Advisor: Nemotron Ultra 253B — deep multi-step financial reasoning & AI advisor chat
# Portfolio: Nemotron Super 49B — fast real-time portfolio analysis & rebalancing
# OCR: Llama 3.2 90B Vision — document & financial statement extraction
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_ADVISOR_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1
NVIDIA_PORTFOLIO_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
NVIDIA_OCR_MODEL=meta/llama-3.2-90b-vision-instruct

# Gemma routing
# Google AI Studio / Gemini API native mode.
# Replace GEMMA_*_MODEL with the official Google-hosted Gemma 4 model ID once Google exposes it.
GEMMA_API_KEY=
GEMMA_API_MODE=google-native
GEMMA_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMMA_ADVISOR_MODEL=gemma-3-27b-it
GEMMA_PORTFOLIO_MODEL=gemma-3-27b-it

# AI routing strategy
# Supported strategies: primary, fallback, merge, ab
AI_ADVISOR_STRATEGY=primary
AI_ADVISOR_PRIMARY_PROVIDER=nvidia
AI_ADVISOR_FALLBACK_PROVIDER=gemma
AI_ADVISOR_AB_TEST_PROVIDER=gemma
AI_ADVISOR_AB_PERCENT=0

AI_PORTFOLIO_STRATEGY=primary
AI_PORTFOLIO_PRIMARY_PROVIDER=nvidia
AI_PORTFOLIO_FALLBACK_PROVIDER=gemma
AI_PORTFOLIO_AB_TEST_PROVIDER=gemma
AI_PORTFOLIO_AB_PERCENT=0

# External Data Providers
DATALAB_API_KEY=
DATALAB_API_BASE=https://www.datalab.to

SAHMK_API_KEY=
SAHMK_API_BASE=https://app.sahmk.sa/api/v1

TWELVEDATA_API_KEY=
TWELVEDATA_API_BASE=https://api.twelvedata.com
